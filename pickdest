let map, markers=[], lines=[], iwins=[];
let currentSlot='all', currentShop=null;
let geoCache={};   // addr → {lat,lng}
let shopGeo={};    // shop_name → {lat,lng}
let destGeo={};    // dest_addr → {lat,lng}

const SLOT_COLORS=['#F59E0B','#10B981','#FF6B35','#7F77DD'];
const ZONE_COLORS={
  '역삼동':'#FF6B35','논현동':'#F59E0B','대치동':'#10B981',
  '신사동':'#7F77DD','삼성동':'#EC4899','청담동':'#06B6D4',
  '서초동':'#84CC16','도곡동':'#F97316','잠원동':'#A855F7',
  '반포동':'#14B8A6','기타':'#888',
};
function zc(z){ return ZONE_COLORS[z]||'#888'; }

map = new naver.maps.Map('map',{
  center: new naver.maps.LatLng(37.502,127.028),
  zoom:13, scaleControl:false,
});

function gc(addr){
  return new Promise((res,rej)=>{
    if(geoCache[addr]){ res(geoCache[addr]); return; }
    naver.maps.Service.geocode({query:addr},(st,resp)=>{
      if(st!==naver.maps.Service.Status.OK){rej();return;}
      const it=resp.v2.addresses;
      if(!it||!it.length){rej();return;}
      const r={lat:parseFloat(it[0].y),lng:parseFloat(it[0].x)};
      geoCache[addr]=r;
      res(r);
    });
  });
}

function ll(lat,lng){ return new naver.maps.LatLng(lat,lng); }
function clr(){
  markers.forEach(m=>m.setMap(null));
  lines.forEach(l=>l.setMap(null));
  iwins.forEach(w=>w.close());
  markers=[]; lines=[]; iwins=[];
}

// 현재 슬롯 데이터
function getShops(){
  return currentSlot==='all' ? DATA.all_shops : (DATA.slot_shops[currentSlot]||[]);
}

// 상점 리스트 렌더
function renderShopList(){
  const shops=getShops();
  const maxCnt=Math.max(...shops.map(s=>s.total));
  document.getElementById('shop-list').innerHTML=shops.map((s,i)=>`
    <div class="shop-item ${currentShop===s.shop?'active':''}" onclick="selectShop('${s.shop.replace(/'/g,"\'")}')">
      <div class="shop-name" title="${s.shop}">${s.shop}</div>
      <div class="shop-meta">
        <span class="shop-cnt">${s.total}건</span>
        <span class="shop-fee">${s.avg_fee.toLocaleString()}원</span>
      </div>
      <div class="shop-zone" style="color:${zc(s.zone)}">${s.zone}</div>
    </div>`).join('');
}

// 배달지 리스트 렌더
function renderDestList(shop){
  if(!shop){
    document.getElementById('dest-list').innerHTML='<div style="padding:12px;font-size:11px;color:#555">상점을 선택하세요</div>';
    return;
  }
  document.getElementById('dest-list').innerHTML=shop.dests.map(([addr,cnt])=>`
    <div class="dest-item" onclick="focusDest('${addr.replace(/'/g,"\'")}')">
      <div class="dest-addr" title="${addr}">${addr.replace('서울특별시 ','').replace('서울 ','')}</div>
      <div class="dest-cnt">${cnt}건</div>
    </div>`).join('');
}

// 상점 선택
async function selectShop(shopName){
  currentShop=shopName;
  renderShopList();

  const shops=getShops();
  const shop=shops.find(s=>s.shop===shopName);
  if(!shop) return;

  renderDestList(shop);

  // 상태바
  document.getElementById('stat-shop').innerHTML=`상점 <span>${shopName.substring(0,15)}</span>`;
  document.getElementById('stat-cnt').innerHTML=`건수 <span>${shop.total}건</span>`;
  document.getElementById('stat-fee').innerHTML=`평균단가 <span>${shop.avg_fee.toLocaleString()}원</span>`;
  document.getElementById('stat-dest').innerHTML=`배달지 <span>${shop.dests.length}곳</span>`;

  clr();

  // 로딩 표시
  const total=1+shop.dests.length;
  let done=0;
  document.getElementById('loading').style.display='flex';
  document.getElementById('loading-text').textContent='주소 변환 중...';

  // 상점 Geocoding
  let shopPos=null;
  try{
    shopPos=await gc(shop.pickup_addr);
    shopGeo[shopName]=shopPos;
  }catch(e){}
  done++;
  document.getElementById('loading-bar').style.width=(done/total*100)+'%';

  // 배달지 Geocoding
  const destPositions=[];
  for(const [addr,cnt] of shop.dests){
    let pos=null;
    try{ pos=await gc(addr); }catch(e){}
    destPositions.push({addr,cnt,pos});
    done++;
    document.getElementById('loading-bar').style.width=(done/total*100)+'%';
    await new Promise(r=>setTimeout(r,50));
  }
  document.getElementById('loading').style.display='none';

  if(!shopPos) return;

  const color=zc(shop.zone);
  const shopLl=ll(shopPos.lat,shopPos.lng);
  const maxCnt=Math.max(...destPositions.map(d=>d.cnt));

  // 상점 마커
  const shopMarker=new naver.maps.Marker({
    map, position:shopLl, zIndex:100,
    icon:{
      content:`<div style="background:${color};border:3px solid #fff;border-radius:10px;padding:4px 8px;font-size:11px;font-weight:700;color:#fff;white-space:nowrap;box-shadow:0 2px 8px rgba(0,0,0,0.5)">${shop.shop.substring(0,12)}</div>`,
      anchor:new naver.maps.Point(0,20),
    }
  });
  markers.push(shopMarker);

  // 배달지 마커 + 연결선
  destPositions.forEach(({addr,cnt,pos},i)=>{
    if(!pos) return;
    const ratio=cnt/maxCnt;
    const destLl=ll(pos.lat,pos.lng);

    // 연결선 (굵기 = 건수 비례)
    const line=new naver.maps.Polyline({
      map,
      path:[shopLl,destLl],
      strokeColor:color,
      strokeWeight:Math.max(1,Math.round(ratio*5)),
      strokeOpacity:0.3+ratio*0.5,
      strokeStyle:'solid',
    });

    // 화살표 (중간 지점)
    const mLat=(shopPos.lat+pos.lat)/2;
    const mLng=(shopPos.lng+pos.lng)/2;
    const angle=Math.atan2(pos.lng-shopPos.lng,pos.lat-shopPos.lat)*180/Math.PI;
    const arrowM=new naver.maps.Marker({
      map,position:ll(mLat,mLng),
      icon:{
        content:`<div style="width:0;height:0;border-left:4px solid transparent;border-right:4px solid transparent;border-bottom:8px solid ${color};transform:rotate(${angle}deg);opacity:${0.4+ratio*0.5};pointer-events:none;"></div>`,
        anchor:new naver.maps.Point(4,4),
      }
    });

    // 배달지 마커
    const sz=Math.max(16,Math.round(ratio*24));
    const destMarker=new naver.maps.Marker({
      map,position:destLl,
      icon:{
        content:`<div style="width:${sz}px;height:${sz}px;border-radius:3px;background:rgba(127,119,221,${0.3+ratio*0.7});border:2px solid #7F77DD;display:flex;align-items:center;justify-content:center;font-size:9px;font-weight:700;color:#fff;">${cnt}</div>`,
        anchor:new naver.maps.Point(sz/2,sz/2),
      }
    });

    // 클릭 시 상세
    const iw=new naver.maps.InfoWindow({
      content:`<div style="background:#1a1a1a;border:1px solid #7F77DD;border-radius:8px;padding:8px 12px;min-width:180px;font-size:11px;">
        <div style="color:#7F77DD;font-weight:700;margin-bottom:4px">📦 배달지</div>
        <div style="color:#ccc;margin-bottom:4px;word-break:break-all">${addr.replace('서울특별시 ','')}</div>
        <div style="color:#FF6B35;font-weight:700">${cnt}건 배달</div>
        <div style="color:#888;font-size:10px;margin-top:2px">${shop.shop} 픽업</div>
      </div>`,
      borderColor:'transparent',backgroundColor:'transparent',borderWidth:0,disableAnchor:true,
    });
    naver.maps.Event.addListener(destMarker,'click',()=>{
      iwins.forEach(w=>w.close());
      iw.open(map,destMarker);
    });

    lines.push(line);
    markers.push(arrowM,destMarker);
    iwins.push(iw);
  });

  // 지도 범위 맞추기
  const validPositions=[shopPos,...destPositions.filter(d=>d.pos).map(d=>d.pos)];
  if(validPositions.length>1){
    const lats=validPositions.map(p=>p.lat);
    const lngs=validPositions.map(p=>p.lng);
    map.fitBounds(new naver.maps.LatLngBounds(
      ll(Math.min(...lats)-0.005,Math.min(...lngs)-0.005),
      ll(Math.max(...lats)+0.005,Math.max(...lngs)+0.005)
    ));
  }
}

function focusDest(addr){
  const pos=geoCache[addr];
  if(pos) map.panTo(ll(pos.lat,pos.lng));
}

function setSlot(slot){
  currentSlot=slot;
  currentShop=null;
  clr();
  document.querySelectorAll('.tab').forEach((t,i)=>{
    const slots=['all','0','1','2','3'];
    t.classList.toggle('active',slots[i]===slot);
  });
  renderShopList();
  renderDestList(null);
  document.getElementById('stat-shop').innerHTML='상점: -';
  document.getElementById('stat-cnt').innerHTML='건수: -';
  document.getElementById('stat-fee').innerHTML='단가: -';
  document.getElementById('stat-dest').innerHTML='배달지: -';
}

// 초기화
naver.maps.Event.addListener(map,'init',()=>{
  renderShopList();
});
setTimeout(()=>renderShopList(),500);
</script>
</body>
</html>
